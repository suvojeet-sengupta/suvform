{
  "name": "suvform-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "logs": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:migrate:local": "wrangler d1 migrations apply suvform-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply suvform-db --remote",
    "start:node": "tsx src/node-entry.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.8.0",
    "hono": "^4.6.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.11.24",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.2",
    "wrangler": "^4.0.0"
  }
}
